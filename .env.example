# ── EasyEcom API Credentials ─────────────────────────────────────────────────
EASYECOM_EMAIL=your_email@example.com
EASYECOM_PASSWORD=your_password
EASYECOM_LOCATION_KEY=your_location_key
EASYECOM_X_API_KEY=your_x_api_key_here
EASYECOM_BASE_URL=https://api.easyecom.io

# ── Shopify Store Credentials ─────────────────────────────────────────────────
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_access_token_here
SHOPIFY_API_VERSION=2024-01

# ── Shopify App OAuth (for npm run shopify-auth only) ─────────────────────────
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Manual sync trigger (POST /sync/trigger with header x-api-key) ───────────
SYNC_API_KEY=your_random_secret_here
